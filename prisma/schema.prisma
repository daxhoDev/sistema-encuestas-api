generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model answers {
  id         BigInt    @id @default(autoincrement())
  survey_id  BigInt?
  responses  Json
  origin_ip  String    @db.Inet
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  deleted_at DateTime? @db.Timestamptz(6)
  surveys    surveys?  @relation(fields: [survey_id], references: [id])
}

model surveys {
  id         BigInt    @id @default(autoincrement())
  name       String
  questions  Json
  is_active  Boolean   @default(false)
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  deleted_at DateTime? @db.Timestamptz(6)
  answers    answers[]
}

model users {
  id         BigInt    @id(map: "profiles_pkey") @default(autoincrement())
  email      String    @unique(map: "profiles_email_key")
  password   String
  username   String    @unique(map: "profiles_username_key")
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  deleted_at DateTime? @db.Timestamptz(6)
}

enum answer_type {
  TEXT_RESPONSE
  SINGLE_SELECT
  MULTI_SELECT
}
